---
import BaseLayout from '@layouts/BaseLayout.astro';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { services } from '@data/portfolio';

const description = "Saint's Touch Photography services and pricing. Portraits, maternity, couples, commercial, boudoir, fashion, weddings & travel photography.";
---

<BaseLayout
  title="Services & Pricing — Saint's Touch Photography"
  description={description}
>
  <!-- LOADER -->
  <div id="loader">
    <div class="loader-title">Saint's Touch Photography</div>
    <div class="loader-sub">by Clifford Roberts III</div>
    <div class="loader-bar-wrap">
      <div class="loader-bar"></div>
    </div>
  </div>

  <!-- MOBILE NAV -->
  <div class="nav-mobile" id="nav-mobile">
    <a href="/">Home</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/services">Services</a>
    <a href="/#about">About</a>
    <a href="/gallery-guide.html">Gallery Guide</a>
    <a href="/#contact">Contact</a>
    <a href="https://wa.me/16195096448" target="_blank" style="color:var(--gold);">WhatsApp ↗</a>
    <a href="https://www.instagram.com/saintogsnaps" target="_blank" style="color:var(--gold);">Instagram ↗</a>
  </div>

  <!-- NAV -->
  <nav id="nav">
    <a href="/" class="nav-logo">Saint's <span>Touch</span></a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/portfolio">Portfolio</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/gallery-guide.html">Gallery Guide</a></li>
      <li><a href="https://www.instagram.com/saintogsnaps" target="_blank">Instagram</a></li>
      <li><a href="https://wa.me/16195096448" target="_blank" class="nav-cta">WhatsApp ↗</a></li>
    </ul>
    <LanguageSwitcher locale="en" />
    <button class="nav-hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- BOOKING URGENCY BANNER -->
  <section id="booking-banner" style="background: linear-gradient(135deg, rgba(201,168,124,0.15) 0%, rgba(201,168,124,0.08) 100%); border-bottom: 1px solid rgba(201,168,124,0.2); padding: 40px 20px; text-align: center;">
    <div style="max-width: 700px; margin: 0 auto;">
      <p style="font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; color: var(--cream); margin-bottom: 12px; font-weight: 300;">
        Now booking fine art portrait sessions for <strong style="color: var(--gold);">Summer 2026</strong>
      </p>
      <p style="color: rgba(232,221,208,0.8); margin-bottom: 24px; font-size: 0.95rem;">Limited availability — secure your session today</p>
      <a href="/#contact" style="display: inline-block; padding: 14px 32px; background: var(--gold); color: var(--black); font-family: 'Inter', sans-serif; font-weight: 500; border-radius: 2px; text-decoration: none; transition: all 0.3s; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;" onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 8px 24px rgba(201,168,124,0.3)';" onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='none';">Inquire Now</a>
    </div>
  </section>

  <!-- PAGE HERO -->
  <section id="services-hero" style="padding: 120px 20px 60px; text-align: center; border-bottom: 1px solid rgba(201,168,124,0.1);">
    <div class="section-label reveal">Complete Offering</div>
    <h1 class="section-title reveal reveal-delay-1">Services & <em>Pricing</em></h1>
    <p style="color: rgba(232,221,208,0.8); margin-top: 24px; max-width: 600px; margin-left: auto; margin-right: auto;">
      Explore all photography services with detailed pricing tiers tailored to your vision and budget.
    </p>
  </section>

  <!-- SERVICES -->
  <section id="services" style="padding: 80px 20px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <p class="services-hint reveal" style="text-align: center; margin-bottom: 60px;">Select a service to explore pricing options</p>

      <div class="services-accordion">
        {services.map((service, i) => (
          <div class={`svc-row reveal reveal-delay-${Math.min(i % 4, 3)}`} data-id={service.id}>

            <!-- Clickable header -->
            <button class="svc-header" aria-expanded="false" aria-controls={`tiers-${service.id}`}>
              <div class="svc-header-left">
                <span class="svc-icon">{service.icon}</span>
                <div>
                  <div class="svc-name">{service.name}</div>
                  <div class="svc-desc">{service.description}</div>
                </div>
              </div>
              <div class="svc-header-right">
                <span class="svc-price-range">{service.priceRange}</span>
                <span class="svc-chevron">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </button>

            <!-- Expandable tier panel -->
            <div class="svc-tiers" id={`tiers-${service.id}`} aria-hidden="true">
              {service.tiers.length > 0 ? (
                <div class="tiers-wrap">
                  {service.tiers.map((tier) => (
                    <div class={`tier-card${tier.featured ? ' featured' : ''}`}>
                      {tier.badge && <div class="tier-badge">{tier.badge}</div>}
                      <div class="tier-label">Tier {tier.num}</div>
                      <div class="tier-name">{tier.name}</div>
                      <div class="tier-price">
                        <sup>$</sup>{tier.price.replace('$', '')}
                        {tier.priceSuffix && <span class="tier-price-suffix">{tier.priceSuffix}</span>}
                      </div>
                      <div class="tier-price-note">{tier.tagline}</div>
                      <div class="tier-divider"></div>
                      <div class="tier-includes">Includes</div>
                      <ul class="tier-features">
                        {tier.features.map((f) => <li>{f}</li>)}
                      </ul>
                      <a href="/#contact" class={`tier-cta ${tier.featured ? 'solid' : 'outline'}`}>Book This Session</a>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="svc-contact-prompt">
                  <p>Pricing for this service is tailored to your specific vision and needs.</p>
                  <a href="/#contact" class="tier-cta outline" style="display:inline-block;margin-top:16px;">Get a Custom Quote</a>
                </div>
              )}
            </div>

          </div>
        ))}

        <!-- Not sure CTA -->
        <div class="svc-cta-row reveal">
          <span style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--dim);">Not sure which fits?</span>
          <a href="https://wa.me/16195096448" target="_blank" class="btn-primary">Let's Talk →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SESSION PREP GUIDE CTA -->
  <section id="guide-cta" style="padding: 100px 20px; background: linear-gradient(180deg, rgba(8,8,8,0) 0%, rgba(201,168,124,0.08) 100%); border-top: 1px solid rgba(201,168,124,0.1);">
    <div style="max-width: 650px; margin: 0 auto; text-align: center;">
      <p style="font-family: 'Cormorant Garamond', serif; font-size: 0.9rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px;">Plan Your Shoot</p>
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; color: var(--cream); margin-bottom: 16px; line-height: 1.2;">
        Not ready to book yet?
      </h2>
      <p style="color: rgba(232,221,208,0.8); font-size: 0.95rem; margin-bottom: 32px; line-height: 1.8;">
        Download our free <strong>Session Planning Guide</strong> and start envisioning your dream shoot. Get exclusive tips, inspiration, and guidance delivered straight to your inbox.
      </p>
      <div style="background: rgba(201,168,124,0.08); border: 1px solid rgba(201,168,124,0.15); padding: 32px; border-radius: 2px; margin-bottom: 24px;">
        <form id="guide-form" style="display: flex; flex-direction: column; gap: 16px;" onsubmit="handleGuideDownload(event)">
          <input 
            type="email" 
            placeholder="your@email.com" 
            required 
            style="background: rgba(8,8,8,0.6); border: 1px solid rgba(201,168,124,0.2); color: var(--cream); padding: 14px 18px; border-radius: 2px; font-family: 'Inter', sans-serif; font-size: 0.9rem; transition: all 0.3s;" 
            onfocus="this.style.borderColor='var(--gold)'; this.style.background='rgba(8,8,8,0.9)';" 
            onblur="this.style.borderColor='rgba(201,168,124,0.2)'; this.style.background='rgba(8,8,8,0.6)';" 
          />
          <button 
            type="submit" 
            style="padding: 14px 32px; background: var(--gold); color: var(--black); border: none; font-family: 'Inter', sans-serif; font-weight: 600; border-radius: 2px; cursor: pointer; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85rem; transition: all 0.3s;" 
            onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 8px 24px rgba(201,168,124,0.3)';" 
            onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='none';"
          >
            Get Free Guide
          </button>
        </form>
        <div id="guide-msg" style="display:none; text-align:center;"></div>
        <p style="font-size: 0.75rem; color: rgba(232,221,208,0.6); text-align: center;">
          We respect your privacy. Unsubscribe anytime.
        </p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-links">
      <a href="https://www.instagram.com/saintogsnaps" target="_blank">Instagram</a>
      <a href="https://wa.me/16195096448" target="_blank">WhatsApp</a>
      <a href="/#contact">Contact</a>
    </div>
    <p>&copy; {new Date().getFullYear()} Saint's Touch Photography. All rights reserved.</p>
  </footer>

  <script is:inline>
    async function handleGuideDownload(e) {
      e.preventDefault();
      const form = e.target;
      const emailInput = form.querySelector('input[type="email"]');
      const submitBtn = form.querySelector('button[type="submit"]');
      const msgEl = document.getElementById('guide-msg');
      const email = emailInput.value.trim();

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      if (msgEl) { msgEl.textContent = ''; msgEl.style.display = 'none'; }

      try {
        const res = await fetch('/api/guide-signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();

        if (data.ok) {
          form.style.display = 'none';
          if (msgEl) {
            msgEl.textContent = '✓ Check your inbox — the guide is on its way!';
            msgEl.style.display = 'block';
            msgEl.style.color = '#8db48e';
            msgEl.style.fontSize = '0.9rem';
            msgEl.style.padding = '16px 0';
          }
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Get Free Guide';
          if (msgEl) {
            msgEl.textContent = data.error || 'Something went wrong. Please try again.';
            msgEl.style.display = 'block';
            msgEl.style.color = '#c47a7a';
            msgEl.style.fontSize = '0.85rem';
            msgEl.style.padding = '12px 0';
          }
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Get Free Guide';
        if (msgEl) {
          msgEl.textContent = 'Network error. Please try again.';
          msgEl.style.display = 'block';
          msgEl.style.color = '#c47a7a';
        }
      }
    }
  </script>

  <script is:inline>
    // LOADER
    window.addEventListener('load', () => {
      const loader = document.getElementById('loader');
      setTimeout(() => {
        loader.classList.add('hidden');
      }, 3000);
    });

    // NAV SCROLL
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });

    // MOBILE NAV
    const hamburger = document.getElementById('hamburger');
    const mobileNav = document.getElementById('nav-mobile');
    let menuOpen = false;

    hamburger.addEventListener('click', () => {
      menuOpen = !menuOpen;
      mobileNav.classList.toggle('open', menuOpen);
      const spans = hamburger.querySelectorAll('span');
      if (menuOpen) {
        spans[0].style.transform = 'translateY(6px) rotate(45deg)';
        spans[1].style.opacity = '0';
        spans[2].style.transform = 'translateY(-6px) rotate(-45deg)';
      } else {
        spans.forEach(s => { s.style.transform = ''; s.style.opacity = ''; });
      }
    });

    window.closeMobileNav = function() {
      menuOpen = false;
      mobileNav.classList.remove('open');
      hamburger.querySelectorAll('span').forEach(s => { s.style.transform = ''; s.style.opacity = ''; });
    };

    mobileNav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (link.getAttribute('href').startsWith('#') || link.getAttribute('href').startsWith('/')) {
          window.closeMobileNav();
        }
      });
    });

    // SCROLL REVEAL
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));

    // ── Services accordion ────────────────────────────────────────
    document.querySelectorAll('.svc-header').forEach(btn => {
      btn.addEventListener('click', () => {
        const row    = btn.closest('.svc-row');
        const panel  = btn.nextElementSibling;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all other open rows
        document.querySelectorAll('.svc-row.open').forEach(openRow => {
          if (openRow !== row) {
            openRow.classList.remove('open');
            const ob = openRow.querySelector('.svc-header');
            const op = openRow.querySelector('.svc-tiers');
            ob.setAttribute('aria-expanded', 'false');
            op.setAttribute('aria-hidden', 'true');
            op.style.maxHeight = '0';
          }
        });

        if (isOpen) {
          row.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          panel.setAttribute('aria-hidden', 'true');
          panel.style.maxHeight = '0';
        } else {
          row.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
          panel.setAttribute('aria-hidden', 'false');
          panel.style.maxHeight = panel.scrollHeight + 'px';
          // Smooth scroll into view after expand
          setTimeout(() => row.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
        }
      });
    });
  </script>
</BaseLayout>
