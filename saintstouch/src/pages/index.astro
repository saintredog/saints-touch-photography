---
import BaseLayout from '@layouts/BaseLayout.astro';
import { portfolioItems, services, processSteps } from '@data/portfolio';

const featuredPortfolio = portfolioItems.filter(item => item.featured);
const description = "Cinematic photography by Clifford Roberts III. Portraits, fashion, events, boudoir, maternity & weddings. Based in Virginia Beach, VA.";
---

<BaseLayout
  title="Saint's Touch Photography — Clifford Roberts III"
  description={description}
>
  <!-- LOADER -->
  <div id="loader">
    <div class="loader-title">Saint's Touch Photography</div>
    <div class="loader-sub">by Clifford Roberts III</div>
    <div class="loader-bar-wrap">
      <div class="loader-bar"></div>
    </div>
  </div>

  <!-- MOBILE NAV -->
  <div class="nav-mobile" id="nav-mobile">
    <a href="#work">Work</a>
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
    <a href="https://wa.me/16562310109" target="_blank" style="color:var(--gold);">WhatsApp ↗</a>
    <a href="https://www.instagram.com/saintogsnaps" target="_blank" style="color:var(--gold);">Instagram ↗</a>
  </div>

  <!-- NAV -->
  <nav id="nav">
    <a href="#" class="nav-logo">Saint's <span>Touch</span></a>
    <ul class="nav-links">
      <li><a href="#work">Work</a></li>
      <li><a href="#services">Services</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#contact">Contact</a></li>
      <li><a href="https://www.instagram.com/saintogsnaps" target="_blank">Instagram</a></li>
      <li><a href="https://wa.me/16562310109" target="_blank" class="nav-cta">WhatsApp ↗</a></li>
    </ul>
    <button class="nav-hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- HERO -->
  <section id="hero">
    <div class="hero-bg" id="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">Virginia Beach · Worldwide</div>
      <h1 class="hero-headline">
        Where light meets<br><em>authentic emotion.</em>
      </h1>
      <p class="hero-sub">Cinematic Portraiture &amp; Visual Storytelling</p>
      <a href="#contact" class="hero-cta">
        Book a Session
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 7H13M7 1L13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
    <div class="hero-scroll">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-section">
    <div class="marquee-track" id="marquee-track">
      <!-- items injected by JS -->
    </div>
  </div>

  <!-- PORTFOLIO -->
  <section id="work">
    <div class="work-header">
      <div>
        <div class="section-label reveal">Selected Work</div>
        <h2 class="section-title reveal reveal-delay-1">The <em>Gallery</em></h2>
      </div>
      <div class="filter-bar reveal reveal-delay-2" id="filter-bar">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="portraits">Portraits</button>
        <button class="filter-btn" data-filter="events">Events</button>
        <button class="filter-btn" data-filter="fashion">Fashion</button>
        <button class="filter-btn" data-filter="couples">Couples</button>
        <button class="filter-btn" data-filter="hospitality">Hospitality</button>
      </div>
    </div>

    <div class="gallery-grid reveal" id="gallery">
      {portfolioItems.map((item) => (
        <div
          class="gallery-item"
          data-category={item.category}
          data-featured={item.featured}
          data-src={item.src}
        >
          <img src={item.src} alt={item.alt} loading="lazy" />
          <div class="gallery-item-overlay">
            <span class="gallery-item-label">
              {item.category.charAt(0).toUpperCase() + item.category.slice(1)}
            </span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox">
    <button id="lightbox-close">&#x2715;</button>
    <button id="lightbox-prev">&#8249;</button>
    <img id="lightbox-img" src="" alt="" />
    <button id="lightbox-next">&#8250;</button>
  </div>

  <!-- SERVICES -->
  <section id="services">
    <div class="section-label reveal">Investment</div>
    <h2 class="section-title reveal reveal-delay-1">Services &amp; <em>Pricing</em></h2>
    <div class="gold-line reveal reveal-delay-2"></div>

    <div class="services-grid">
      {services.map((service, i) => (
        <div class={`service-card reveal reveal-delay-${Math.min(i, 3)}`}>
          <div class="service-icon">{service.icon}</div>
          <div class="service-name">{service.name}</div>
          <div class="service-price">{service.price}</div>
          <p class="service-desc">{service.description}</p>
        </div>
      ))}
    </div>

    <div class="gold-line reveal" style="margin-top: 80px;"></div>
    <div class="reveal" style="text-align: center; margin-top: 60px;">
      <p style="font-size: 0.95rem; color: rgba(232,221,208,0.8); line-height: 1.8; margin-bottom: 32px;">
        Rates vary by session type, location, and deliverables. Travel outside the 25-mile radius incurs a travel fee.
      </p>
      <a href="#contact" class="hero-cta">Get a Custom Quote</a>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div class="section-label reveal">How It Works</div>
      <h2 class="section-title reveal reveal-delay-1">The <em>Process</em></h2>

      <div class="process-steps">
        {processSteps.map((item) => (
          <div class={`process-step reveal reveal-delay-${Math.min(item.step - 1, 3)}`}>
            <div class="process-step-num">{String(item.step).padStart(2, '0')}</div>
            <div class="process-step-title">{item.title}</div>
            <div class="process-step-desc">{item.description}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="about-content">
      <div class="section-label reveal">About</div>
      <h2 class="section-title reveal reveal-delay-1">Meet <em>Cliff</em></h2>

      <div class="about-image reveal reveal-delay-2">
        <img src="images/REG2.jpg" alt="Clifford Roberts III" />
      </div>

      <div class="about-intro reveal reveal-delay-1">
        I'm Clifford Roberts III, a visual storyteller based in Virginia Beach with a passion for cinematic photography.
      </div>

      <div class="about-text reveal reveal-delay-2">
        For the past several years, I've dedicated myself to capturing the raw emotion and authentic moments that define
        life's most important stories. Whether it's a maternity session celebrating new beginnings, a fashion editorial
        pushing creative boundaries, or an intimate couples moment — I approach every frame with intentionality and artistry.
        <br />
        <br />
        My style blends technical mastery with genuine human connection. I don't just take photos; I create visual narratives
        that resonate. Each session is a collaboration, and every image tells part of your story.
        <br />
        <br />
        When I'm not shooting, you'll find me exploring light, pushing creative boundaries, or investing in my growth — both
        as a photographer and as a person.
      </div>

      <a href="#contact" class="hero-cta">Work Together</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="contact-content">
      <div class="section-label reveal">Get In Touch</div>
      <h2 class="section-title reveal reveal-delay-1">Let's Create <em>Something</em></h2>

      <form class="contact-form reveal reveal-delay-2" action="https://formspree.io/f/xyzljkqo" method="POST">
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="phone">Phone (Optional)</label>
          <input type="tel" id="phone" name="phone" />
        </div>

        <div class="form-group">
          <label for="service">Service Interested In</label>
          <select id="service" name="service" required style="padding: 16px; background: rgba(232,221,208,0.05); border: 1px solid rgba(201,168,124,0.2); color: var(--cream); font-family: inherit; font-size: 0.95rem; border-radius: 2px;">
            <option value="">Select a service</option>
            <option value="portraits">Portraits</option>
            <option value="maternity">Maternity</option>
            <option value="fashion">Fashion</option>
            <option value="couples">Couples & Engagements</option>
            <option value="events">Events</option>
            <option value="commercial">Commercial / Hospitality</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Tell Me About Your Vision</label>
          <textarea id="message" name="message" required></textarea>
        </div>

        <button type="submit" class="form-submit">Send Inquiry</button>
      </form>

      <div style="margin-top: 80px; padding-top: 60px; border-top: 1px solid rgba(201,168,124,0.1);">
        <p style="font-size: 0.95rem; color: rgba(232,221,208,0.8); margin-bottom: 24px;">
          Prefer to reach out directly?
        </p>
        <div style="display: flex; justify-content: center; gap: 32px; flex-wrap: wrap;">
          <a href="https://wa.me/16562310109" target="_blank" style="color: var(--gold); font-weight: 500;">WhatsApp: +1 (656) 231-0109</a>
          <a href="https://www.instagram.com/saintogsnaps" target="_blank" style="color: var(--gold); font-weight: 500;">@saintogsnaps</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-links">
      <a href="https://www.instagram.com/saintogsnaps" target="_blank">Instagram</a>
      <a href="https://wa.me/16562310109" target="_blank">WhatsApp</a>
      <a href="#contact">Contact</a>
    </div>
    <p>&copy; {new Date().getFullYear()} Saint's Touch Photography. All rights reserved.</p>
  </footer>

  <script is:inline>
    // LOADER
    window.addEventListener('load', () => {
      const loader = document.getElementById('loader');
      setTimeout(() => {
        loader.classList.add('hidden');
        const heroBg = document.getElementById('hero-bg');
        if (heroBg) heroBg.classList.add('loaded');
      }, 3000);
    });

    // NAV SCROLL
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });

    // MOBILE NAV
    const hamburger = document.getElementById('hamburger');
    const mobileNav = document.getElementById('nav-mobile');
    let menuOpen = false;

    hamburger.addEventListener('click', () => {
      menuOpen = !menuOpen;
      mobileNav.classList.toggle('open', menuOpen);
      const spans = hamburger.querySelectorAll('span');
      if (menuOpen) {
        spans[0].style.transform = 'translateY(6px) rotate(45deg)';
        spans[1].style.opacity = '0';
        spans[2].style.transform = 'translateY(-6px) rotate(-45deg)';
      } else {
        spans.forEach(s => { s.style.transform = ''; s.style.opacity = ''; });
      }
    });

    window.closeMobileNav = function() {
      menuOpen = false;
      mobileNav.classList.remove('open');
      hamburger.querySelectorAll('span').forEach(s => { s.style.transform = ''; s.style.opacity = ''; });
    };

    mobileNav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (link.getAttribute('href').startsWith('#')) {
          window.closeMobileNav();
        }
      });
    });

    // MARQUEE
    const marqueeItems = ['Portrait','Events','Fashion','Boudoir','Maternity','Weddings','Virginia Beach'];
    const track = document.getElementById('marquee-track');
    const repeat = 6;
    let html = '';
    for (let r = 0; r < repeat; r++) {
      marqueeItems.forEach((item, i) => {
        html += `<div class="marquee-item">${item}${i < marqueeItems.length - 1 ? '<span class="marquee-dot">●</span>' : ''}</div>`;
      });
    }
    track.innerHTML = html;

    // PORTFOLIO FILTER & LIGHTBOX
    const filterBtns = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll('.gallery-item');
    const lightbox = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightbox-img');
    const lbClose = document.getElementById('lightbox-close');
    const lbPrev = document.getElementById('lightbox-prev');
    const lbNext = document.getElementById('lightbox-next');
    let visibleItems = [];
    let lbIndex = 0;

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        galleryItems.forEach(item => {
          const show = filter === 'all'
            ? item.dataset.featured === 'true'
            : item.dataset.category === filter;
          if (show) {
            item.classList.remove('hidden');
            item.style.animation = 'none';
            item.offsetHeight;
            item.style.animation = '';
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });

    // Init: show only featured on load
    galleryItems.forEach(item => {
      if (item.dataset.featured !== 'true') item.classList.add('hidden');
    });

    function getVisibleItems() {
      return [...document.querySelectorAll('.gallery-item:not(.hidden)')];
    }

    galleryItems.forEach(item => {
      item.addEventListener('click', () => {
        visibleItems = getVisibleItems();
        lbIndex = visibleItems.indexOf(item);
        openLightbox(lbIndex);
      });
    });

    function openLightbox(idx) {
      lbImg.src = visibleItems[idx].dataset.src;
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    }

    lbClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
    lbPrev.addEventListener('click', () => { lbIndex = (lbIndex - 1 + visibleItems.length) % visibleItems.length; openLightbox(lbIndex); });
    lbNext.addEventListener('click', () => { lbIndex = (lbIndex + 1) % visibleItems.length; openLightbox(lbIndex); });

    document.addEventListener('keydown', e => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft')  { lbIndex = (lbIndex - 1 + visibleItems.length) % visibleItems.length; openLightbox(lbIndex); }
      if (e.key === 'ArrowRight') { lbIndex = (lbIndex + 1) % visibleItems.length; openLightbox(lbIndex); }
    });

    // SCROLL REVEAL
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));
  </script>
</BaseLayout>
