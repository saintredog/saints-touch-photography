---
import BaseLayoutI18n from '@layouts/BaseLayoutI18n.astro';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { services } from '@data/portfolio';
import { t } from '@i18n/utils';
import type { Locale } from '@i18n/utils';

const locale: Locale = 'pt-br';
---

<BaseLayoutI18n
  title={`${t(locale, 'services_page.hero.title')}${t(locale, 'services_page.hero.titleEmphasis')} — Saint's Touch Photography`}
  description={t(locale, 'services_page.description')}
  locale={locale}
>
  <!-- LOADER -->
  <div id="loader">
    <div class="loader-title">Saint's Touch Photography</div>
    <div class="loader-sub">by Clifford Roberts III</div>
    <div class="loader-bar-wrap">
      <div class="loader-bar"></div>
    </div>
  </div>

  <!-- MOBILE NAV -->
  <div class="nav-mobile" id="nav-mobile">
    <a href="/pt-br/">{t(locale, 'nav.work')}</a>
    <a href="/pt-br/portfolio">Portfolio</a>
    <a href="/pt-br/services">{t(locale, 'nav.services')}</a>
    <a href="/pt-br/#about">{t(locale, 'nav.about')}</a>
    <a href="/gallery-guide.html">{t(locale, 'nav.gallery')}</a>
    <a href="/pt-br/#contact">{t(locale, 'nav.contact')}</a>
    <a href="https://wa.me/16562310109" target="_blank" style="color:var(--gold);">WhatsApp ↗</a>
    <a href="https://www.instagram.com/saintogsnaps" target="_blank" style="color:var(--gold);">Instagram ↗</a>
  </div>

  <!-- NAV -->
  <nav id="nav">
    <a href="/pt-br/" class="nav-logo">Saint's <span>Touch</span></a>
    <ul class="nav-links">
      <li><a href="/pt-br/">{t(locale, 'nav.work')}</a></li>
      <li><a href="/pt-br/portfolio">Portfolio</a></li>
      <li><a href="/pt-br/services">{t(locale, 'nav.services')}</a></li>
      <li><a href="/pt-br/#about">{t(locale, 'nav.about')}</a></li>
      <li><a href="https://www.instagram.com/saintogsnaps" target="_blank">Instagram</a></li>
      <li><a href="https://wa.me/16562310109" target="_blank" class="nav-cta">WhatsApp ↗</a></li>
    </ul>
    <LanguageSwitcher locale={locale} />
    <button class="nav-hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- BOOKING URGENCY BANNER -->
  <section id="booking-banner" style="background: linear-gradient(135deg, rgba(201,168,124,0.15) 0%, rgba(201,168,124,0.08) 100%); border-bottom: 1px solid rgba(201,168,124,0.2); padding: 40px 20px; text-align: center;">
    <div style="max-width: 700px; margin: 0 auto;">
      <p style="font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; color: var(--cream); margin-bottom: 12px; font-weight: 300;">
        Agora marcando sessões de retratos artísticos para <strong style="color: var(--gold);">Verão 2026</strong>
      </p>
      <p style="color: rgba(232,221,208,0.8); margin-bottom: 24px; font-size: 0.95rem;">Disponibilidade limitada — garanta sua sessão hoje</p>
      <a href="/pt-br/#contact" style="display: inline-block; padding: 14px 32px; background: var(--gold); color: var(--black); font-family: 'Inter', sans-serif; font-weight: 500; border-radius: 2px; text-decoration: none; transition: all 0.3s; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;" onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 8px 24px rgba(201,168,124,0.3)';" onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='none';">Consulte</a>
    </div>
  </section>

  <!-- PAGE HERO -->
  <section id="services-hero" style="padding: 120px 20px 60px; text-align: center; border-bottom: 1px solid rgba(201,168,124,0.1);">
    <div class="section-label reveal">{t(locale, 'services_page.hero.label')}</div>
    <h1 class="section-title reveal reveal-delay-1">{t(locale, 'services_page.hero.title')}<em>{t(locale, 'services_page.hero.titleEmphasis')}</em></h1>
    <p style="color: rgba(232,221,208,0.8); margin-top: 24px; max-width: 600px; margin-left: auto; margin-right: auto;">
      {t(locale, 'services_page.description')}
    </p>
  </section>

  <!-- SERVICES -->
  <section id="services" style="padding: 80px 20px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <p class="services-hint reveal" style="text-align: center; margin-bottom: 60px;">{t(locale, 'services.hint')}</p>

      <div class="services-accordion">
        {services.map((service, i) => (
          <div class={`svc-row reveal reveal-delay-${Math.min(i % 4, 3)}`} data-id={service.id}>
            <button class="svc-header" aria-expanded="false" aria-controls={`tiers-${service.id}`}>
              <div class="svc-header-left">
                <span class="svc-icon">{service.icon}</span>
                <div>
                  <div class="svc-name">{service.name}</div>
                  <div class="svc-desc">{service.description}</div>
                </div>
              </div>
              <div class="svc-header-right">
                <span class="svc-price-range">{service.priceRange}</span>
                <span class="svc-chevron">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </button>
            <div class="svc-tiers" id={`tiers-${service.id}`} aria-hidden="true">
              {service.tiers.length > 0 ? (
                <div class="tiers-wrap">
                  {service.tiers.map((tier) => (
                    <div class={`tier-card${tier.featured ? ' featured' : ''}`}>
                      {tier.badge && <div class="tier-badge">{tier.badge}</div>}
                      <div class="tier-label">Tier {tier.num}</div>
                      <div class="tier-name">{tier.name}</div>
                      <div class="tier-price"><sup>$</sup>{tier.price.replace('$', '')}{tier.priceSuffix && <span class="tier-price-suffix">{tier.priceSuffix}</span>}</div>
                      <div class="tier-price-note">{tier.tagline}</div>
                      <div class="tier-divider"></div>
                      <div class="tier-includes">Includes</div>
                      <ul class="tier-features">{tier.features.map((f) => <li>{f}</li>)}</ul>
                      <a href="/pt-br/#contact" class={`tier-cta ${tier.featured ? 'solid' : 'outline'}`}>{t(locale, 'hero.cta')}</a>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="svc-contact-prompt">
                  <p>Pricing for this service is tailored to your specific vision and needs.</p>
                  <a href="/pt-br/#contact" class="tier-cta outline" style="display:inline-block;margin-top:16px;">{t(locale, 'about.cta')}</a>
                </div>
              )}
            </div>
          </div>
        ))}
        <div class="svc-cta-row reveal">
          <span style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--dim);">Not sure which fits?</span>
          <a href="https://wa.me/16562310109" target="_blank" class="btn-primary">Let's Talk →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SESSION PREP GUIDE CTA -->
  <section id="guide-cta" style="padding: 100px 20px; background: linear-gradient(180deg, rgba(8,8,8,0) 0%, rgba(201,168,124,0.08) 100%); border-top: 1px solid rgba(201,168,124,0.1);">
    <div style="max-width: 650px; margin: 0 auto; text-align: center;">
      <p style="font-family: 'Cormorant Garamond', serif; font-size: 0.9rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px;">Planeje Sua Sessão</p>
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; color: var(--cream); margin-bottom: 16px; line-height: 1.2;">
        Não está pronto para marcar ainda?
      </h2>
      <p style="color: rgba(232,221,208,0.8); font-size: 0.95rem; margin-bottom: 32px; line-height: 1.8;">
        Baixe nosso <strong>Guia Gratuito de Planejamento de Sessão</strong> e comece a visualizar seu ensaio dos sonhos. Obtenha dicas exclusivas entregues direto na sua caixa de entrada.
      </p>
      <div style="background: rgba(201,168,124,0.08); border: 1px solid rgba(201,168,124,0.15); padding: 32px; border-radius: 2px; margin-bottom: 24px;">
        <form id="guide-form" style="display: flex; flex-direction: column; gap: 16px;" onsubmit="handleGuideDownload(event)">
          <input 
            type="email" 
            placeholder="seu@email.com" 
            required 
            style="background: rgba(8,8,8,0.6); border: 1px solid rgba(201,168,124,0.2); color: var(--cream); padding: 14px 18px; border-radius: 2px; font-family: 'Inter', sans-serif; font-size: 0.9rem; transition: all 0.3s;" 
            onfocus="this.style.borderColor='var(--gold)'; this.style.background='rgba(8,8,8,0.9)';" 
            onblur="this.style.borderColor='rgba(201,168,124,0.2)'; this.style.background='rgba(8,8,8,0.6)';" 
          />
          <button 
            type="submit" 
            style="padding: 14px 32px; background: var(--gold); color: var(--black); border: none; font-family: 'Inter', sans-serif; font-weight: 600; border-radius: 2px; cursor: pointer; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85rem; transition: all 0.3s;" 
            onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 8px 24px rgba(201,168,124,0.3)';" 
            onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='none';"
          >
            Obter Guia Gratuito
          </button>
        </form>
        <p style="font-size: 0.75rem; color: rgba(232,221,208,0.6); text-align: center;">
          Respeitamos sua privacidade. Cancelar inscrição a qualquer momento.
        </p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-links">
      <a href="https://www.instagram.com/saintogsnaps" target="_blank">{t(locale, 'footer.links.instagram')}</a>
      <a href="https://wa.me/16562310109" target="_blank">{t(locale, 'footer.links.whatsapp')}</a>
      <a href="/pt-br/#contact">{t(locale, 'footer.links.contact')}</a>
    </div>
    <p>{t(locale, 'footer.copyright', { year: new Date().getFullYear() })}</p>
  </footer>

  <script is:inline>
    function handleGuideDownload(e) {
      e.preventDefault();
      const email = e.target.querySelector('input[type="email"]').value;
      alert('Obrigado! Verifique seu email para obter o Guia de Planejamento de Sessão.');
      e.target.reset();
    }
  </script>

  <script is:inline>
    window.addEventListener('load', () => { const loader = document.getElementById('loader'); setTimeout(() => loader.classList.add('hidden'), 3000); });
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 60), { passive: true });
    const hamburger = document.getElementById('hamburger');
    const mobileNav = document.getElementById('nav-mobile');
    let menuOpen = false;
    hamburger.addEventListener('click', () => {
      menuOpen = !menuOpen;
      mobileNav.classList.toggle('open', menuOpen);
      const spans = hamburger.querySelectorAll('span');
      if (menuOpen) { spans[0].style.transform='translateY(6px) rotate(45deg)'; spans[1].style.opacity='0'; spans[2].style.transform='translateY(-6px) rotate(-45deg)'; }
      else { spans.forEach(s => { s.style.transform=''; s.style.opacity=''; }); }
    });
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => { entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } }); }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => observer.observe(el));
    document.querySelectorAll('.svc-header').forEach(btn => {
      btn.addEventListener('click', () => {
        const row = btn.closest('.svc-row');
        const panel = btn.nextElementSibling;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.svc-row.open').forEach(openRow => {
          if (openRow !== row) { openRow.classList.remove('open'); openRow.querySelector('.svc-header').setAttribute('aria-expanded','false'); const op=openRow.querySelector('.svc-tiers'); op.setAttribute('aria-hidden','true'); op.style.maxHeight='0'; }
        });
        if (isOpen) { row.classList.remove('open'); btn.setAttribute('aria-expanded','false'); panel.setAttribute('aria-hidden','true'); panel.style.maxHeight='0'; }
        else { row.classList.add('open'); btn.setAttribute('aria-expanded','true'); panel.setAttribute('aria-hidden','false'); panel.style.maxHeight=panel.scrollHeight+'px'; setTimeout(() => row.scrollIntoView({ behavior:'smooth', block:'nearest' }), 50); }
      });
    });
  </script>
</BaseLayoutI18n>
